# Step 8 GKE deployment configuration
# Copy this file to deployments/gke/gke.env and edit values.

# Your Google Cloud project id
PROJECT_ID="dataengineering-496300"

# Region for Artifact Registry and GKE
REGION="us-central1"

# Zone for a small zonal GKE cluster
ZONE="us-central1-a"

# Artifact Registry Docker repository name
AR_REPO="resiliency-repo"

# GKE cluster name
CLUSTER_NAME="resiliency-gke"

# Kubernetes namespace
K8S_NAMESPACE="resiliency"

# Image tag for this deployment
IMAGE_TAG="step8"

# Machine type for cost-conscious demo use
MACHINE_TYPE="e2-standard-2"

# Number of nodes for demo cluster
NUM_NODES="2"
