# deployments/gke/gke.env
# GKE cluster configuration for the Global Service Resiliency project.
# Sourced by step10_deploy.sh and step10_build.sh.

PROJECT_ID=dataengineering-496300
CLUSTER_NAME=resiliency-gke
ZONE=us-central1-a
REGION=us-central1
NUM_NODES=2
MACHINE_TYPE=e2-standard-2
NAMESPACE=resiliency
IMAGE_TAG=step10
REGISTRY=us-central1-docker.pkg.dev/${PROJECT_ID}/resiliency-repo

# Services to build and push
SERVICES="ingestor transformer aggregator healthcheck router api dashboard"

# ── Cluster B (us-west1) — second active cluster for active-active deployment ──
CLUSTER_B_NAME=resiliency-gke-b
CLUSTER_B_ZONE=us-west1-a
CLUSTER_B_REGION=us-west1
