# Copy this to .env and fill in real values. Never commit .env to source control.

# MongoDB Atlas
MONGODB_URI=replace_with_mongodb_atlas_connection_string
MONGODB_DB_NAME=resiliency

# GitHub Events API
GITHUB_TOKEN=<your_github_personal_access_token>

# OpenWeatherMap API
OWM_API_KEY=<your_openweathermap_api_key>

# Service ports
INGESTOR_PORT=8081
TRANSFORMER_PORT=8082
AGGREGATOR_PORT=8085
HEALTHCHECK_PORT=8083
ROUTER_PORT=8084
API_PORT=8080

# Region identifier — set per deployment
REGION=us-east1

# Regions monitored by the healthcheck service
MONITORED_REGIONS=us-east,us-west,europe,asia

# Ingestor schedule (seconds between runs)
INGESTOR_INTERVAL_SECONDS=300
TRANSFORMER_INTERVAL_SECONDS=600
AGGREGATOR_INTERVAL_SECONDS=900
HEALTHCHECK_INTERVAL_SECONDS=30
ROUTER_INTERVAL_SECONDS=30

# Health status thresholds
HEALTH_DEGRADED_MS=250
HEALTH_DOWN_MS=1000

# Routing freshness threshold. Region health rows older than this are ignored.
ROUTING_MAX_AGE_SECONDS=3600

# Dashboard
DASHBOARD_PORT=8501
API_BASE_URL=http://localhost:8080
DASHBOARD_REQUEST_TIMEOUT_SECONDS=10
